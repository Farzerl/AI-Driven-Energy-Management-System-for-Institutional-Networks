# Copy to .env only for local or controlled deployment.
# Never commit the completed .env file.

# Optional write-endpoint key. Leave unset for the public local dashboard demo.
AI4I_API_KEY=replace-with-a-long-random-value

# Optional public evidence directory.
# AI4I_EVIDENCE_DIR=evidence/public_dashboard

# Optional local runtime paths. These directories are ignored by Git.
# AI4I_OPERATOR_LOG=runtime/operator_decisions.jsonl
# AI4I_METER_STORE=runtime/meter_readings.jsonl
# AI4I_EDGE_STATUS=runtime/edge_status.json
# AI4I_COST_IMPACT_DIR=evidence/cost_impact

# Optional pip mirror and timeout controls for slow networks.
# AI4I_PIP_TIMEOUT=300
# AI4I_PIP_RETRIES=10
# AI4I_PIP_INDEX_URL=https://approved-package-mirror.example/simple

# Optional live inference paths
AI4I_MODEL_PATH=
AI4I_FORECAST_STORE=runtime/live_forecasts.jsonl
